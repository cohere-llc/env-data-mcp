# env-data-mcp — credential template
# Copy this file to .env and fill in the values you need.
# Never commit .env to version control.

# ── NASA EarthData (OCO-2, EMIT) ────────────────────────────────────────────
# Free registration: https://urs.earthdata.nasa.gov/
# Generate a token: Profile → Generate Token (up to 2 active tokens at a time)
# The token is passed as:  Authorization: Bearer <token>
EARTHDATA_TOKEN=

# ── OpenAQ ───────────────────────────────────────────────────────────────────
# Free registration: https://explore.openaq.org/
# Generate a key: Account → API Keys
OPENAQ_API_KEY=

# ── ESS-DIVE [DEFERRED — account registration pending] ───────────────────────
# Free registration: https://data.ess-dive.lbl.gov/
# Generate a token: Account → API Tokens
# ESSDIVE_TOKEN=

# ── Google Earth Engine [DEFERRED — exploring free-tier alternatives] ─────────
# Requires a GEE-enabled Google Cloud project and a service account key.
# See: https://developers.google.com/earth-engine/guides/service_account
# GOOGLE_APPLICATION_CREDENTIALS=
